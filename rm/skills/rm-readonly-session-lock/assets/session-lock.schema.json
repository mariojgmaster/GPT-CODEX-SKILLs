{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RmReadonlySessionLock",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "session_id",
    "access_mode",
    "environment_contexts",
    "flosum_context",
    "git_context",
    "machine_context",
    "tooling_context",
    "confirmed_by",
    "confirmed_at",
    "expires_at"
  ],
  "properties": {
    "session_id": { "type": "string" },
    "access_mode": {
      "type": "string",
      "const": "read_only"
    },
    "environment_contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "org_name", "org_id", "instance_url", "username_or_email"],
        "properties": {
          "role": { "type": "string" },
          "org_name": { "type": "string" },
          "org_id": { "type": "string" },
          "instance_url": { "type": "string" },
          "username_or_email": { "type": "string" }
        }
      }
    },
    "flosum_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tenant_or_org", "branch_or_baseline", "package_or_release"],
      "properties": {
        "tenant_or_org": { "type": "string" },
        "branch_or_baseline": { "type": "string" },
        "package_or_release": { "type": "string" }
      }
    },
    "git_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_path", "branch", "remote", "user_name", "user_email"],
      "properties": {
        "repo_path": { "type": "string" },
        "branch": { "type": "string" },
        "remote": { "type": "string" },
        "user_name": { "type": "string" },
        "user_email": { "type": "string" }
      }
    },
    "machine_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hostname", "current_user", "os_platform", "workspace_path"],
      "properties": {
        "hostname": { "type": "string" },
        "current_user": { "type": "string" },
        "os_platform": { "type": "string" },
        "workspace_path": { "type": "string" }
      }
    },
    "tooling_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sf_cli_available", "sf_cli_version"],
      "properties": {
        "sf_cli_available": { "type": "boolean" },
        "sf_cli_version": { "type": "string" },
        "sf_default_org_name": { "type": "string" },
        "sf_default_org_id": { "type": "string" },
        "sf_default_instance_url": { "type": "string" },
        "sf_default_username": { "type": "string" }
      }
    },
    "confirmed_by": { "type": "string" },
    "confirmed_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" }
  }
}
