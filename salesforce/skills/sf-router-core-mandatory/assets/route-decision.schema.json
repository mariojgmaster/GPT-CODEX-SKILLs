{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RouteDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_type",
    "domain",
    "risk_level",
    "primary_skill",
    "secondary_skills",
    "needs_confirmation",
    "confidence",
    "token_budget"
  ],
  "properties": {
    "task_type": {
      "type": "string",
      "description": "Normalized intent label."
    },
    "domain": {
      "type": "string",
      "description": "Execution domain such as salesforce, git, or general."
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "primary_skill": {
      "type": "string"
    },
    "secondary_skills": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 1
    },
    "needs_confirmation": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "token_budget": {
      "type": "string",
      "enum": ["very_low", "low", "medium", "high"]
    }
  }
}

