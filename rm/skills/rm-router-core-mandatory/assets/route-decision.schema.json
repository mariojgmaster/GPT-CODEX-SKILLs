{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RmRouteDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_type",
    "domain",
    "risk_level",
    "primary_skill",
    "secondary_skills",
    "needs_confirmation",
    "confidence",
    "token_budget",
    "readonly_mode",
    "evidence_sources",
    "refusal_required",
    "write_scope"
  ],
  "properties": {
    "task_type": { "type": "string" },
    "domain": { "type": "string" },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "primary_skill": { "type": "string" },
    "secondary_skills": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 1
    },
    "needs_confirmation": { "type": "boolean" },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "token_budget": {
      "type": "string",
      "enum": ["very_low", "low", "medium", "high"]
    },
    "readonly_mode": {
      "type": "boolean",
      "const": true
    },
    "evidence_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "refusal_required": { "type": "boolean" }
    ,
    "write_scope": {
      "type": "string",
      "enum": ["none", "rm_internal_only", "documentation_output_only"]
    }
  }
}
