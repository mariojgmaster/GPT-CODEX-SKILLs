{
  "name": "@mariojgmaster/skill-orchestrator",
  "version": "0.7.0",
  "description": "CLI for listing, installing, and validating Codex skills from the GPT-CODEX-SKILLs catalog.",
  "type": "module",
  "bin": {
    "codex-skills": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --target node20 --clean",
    "test": "vitest run",
    "smoke": "node dist/cli.js doctor repo ../..",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "^12.1.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
